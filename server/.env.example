PORT=4200

# --- 외부 시세 (선택) ---
# CoinGecko 공개 API로 BTC·ETH 행 실시간 병합 (1/true 켬). 실패 시 더미 유지.
# ONEAI_COINGECKO=1
# ONEAI_COINGECKO_TIMEOUT_MS=8000

# Finnhub — 미국 ETF/지수 프록시로 NASDAQ 행 덮어씀 (FINNHUB_API_KEY 필요 · 무료 등록)
# FINNHUB_API_KEY=
# ONEAI_FINNHUB_SYMBOL=QQQ
# ONEAI_FINNHUB_TIMEOUT_MS=8000
# Finnhub 시장 뉴스 → GET /api/news (키 + 아래 플래그 동시 필요)
# ONEAI_FINNHUB_NEWS=1
# ONEAI_FINNHUB_NEWS_CATEGORY=general
# ONEAI_FINNHUB_NEWS_LIMIT=10
# ONEAI_FINNHUB_NEWS_TIMEOUT_MS=10000

# Yahoo Chart (비공식) — KOSPI(^KS11) 행 병합. 일부 환경에서 차단될 수 있음.
# ONEAI_YAHOO_KOSPI=1
# ONEAI_YAHOO_SYMBOL=%5EKS11
# ONEAI_YAHOO_TIMEOUT_MS=10000
# ONEAI_YAHOO_USER_AGENT=Mozilla/5.0 (compatible; OneAI/1.0)

# 프로덕션: PostgreSQL 연결 시 회원/결제 데이터 영속화 (미설정 시 파일 저장소 사용)
# DATABASE_URL=postgresql://oneai:oneai_dev_local@localhost:5432/oneai
ONEAI_ADMIN_TOKEN=change-this-admin-token
ONEAI_TOKEN_SECRET=change-this-token-secret
ONEAI_TOKEN_EXPIRES_HOURS=12
ONEAI_REFRESH_EXPIRES_DAYS=14
ONEAI_MEMBERSHIP_DEPOSIT_ADDRESS=0xYOUR_TREASURY_WALLET
ONEAI_MEMBERSHIP_WEBHOOK_SECRET=change-this-membership-webhook-secret
